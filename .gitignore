# Hidden files/dirs never get committed (.claude, .DS_Store, logs, local state…)
# — except the whitelisted ones below that the repo/deploy actually needs
.*
!.gitignore
!.env.example
!.dockerignore

# API keys live in .env — never commit it (.env.example is the safe template)
.env

# Ignore the API usage JSON file
skills/system/mysys.md
tools/subsec/voice/server.pem
.auto-f
ai-history
tools/agentic/fusion/logs
index-map-local-ai.txt
.active_cd*
.request_log
.agent

# Ignore Python cache directories and bytecode
__pycache__/
*.pyc

# Multi-agent app: local state and build artifacts
.sessions/
mcp.json
.venv/

# GUI app stays local-only (not published to GitHub)
gui/

# Persistent /settings user config stays local
settings.json

# Runtime user data — every install keeps its own; none of it belongs in git
# (workspace databases, spend ledger, project workspaces, session/team caches)
projects/*
!projects/Readme.md
history.md
index-map-*.txt
