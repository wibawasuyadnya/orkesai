#!/usr/bin/env bash
# DotAI launcher for npm-global installs (`npm install -g wibawasuyadnya/local-ai-main`).
# First run bootstraps ~/.config/local-ai from the npm package copy via
# install.sh, then every run just launches the agent.
#
#   dotai            interactive chat
#   dotai <question> one-shot question
#   dotai update     re-run the installer (pull the latest code)
set -euo pipefail

DIR="$HOME/.config/local-ai"
PKG="$(cd "$(dirname "$(readlink "$0" || echo "$0")")/.." && pwd)"

if [ "${1:-}" = "update" ]; then
    bash "$PKG/install.sh"
    exit 0
fi

if [ ! -f "$DIR/ai-agent.py" ]; then
    bash "$PKG/install.sh" --local "$PKG"
fi

exec python3 "$DIR/ai-agent.py" --talk "$@"
