{
  "name": "orkesai-gui",
  "version": "0.11.1",
  "private": true,
  "description": "OrkesAI multi-agent web GUI (Next.js) + Electron shell",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron": "electron .",
    "app": "concurrently -k \"next dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "dist": "BUILD_TARGET=electron next build && electron-builder --mac dmg"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "electron": "^37.10.3",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.0",
    "wait-on": "^8.0.0"
  },
  "allowScripts": {
    "electron@37.10.3": true
  },
  "build": {
    "appId": "com.suyadnya.orkesai",
    "productName": "OrkesAI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "out/**",
      "assets/**",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/orkesai.icns",
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "dmg": {
      "title": "OrkesAI",
      "icon": "assets/orkesai.icns"
    },
    "artifactName": "OrkesAI-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/orkesai-icon.png"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": true
    },
    "extraResources": [
      {
        "from": "../server",
        "to": "payload/server",
        "filter": [
          "**/*.py"
        ]
      },
      {
        "from": "../modules",
        "to": "payload/modules",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "../agents.json",
        "to": "payload/agents.json"
      },
      {
        "from": "../.env.example",
        "to": "payload/.env.example"
      },
      {
        "from": "python-runtime",
        "to": "python"
      }
    ],
    "afterPack": "electron/afterPack.js"
  },
  "author": "Agus Wibawa"
}
