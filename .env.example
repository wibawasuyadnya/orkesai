# ─────────────────────────────────────────────────────────────────────────────
# Local-AI Agent configuration
#
#   cp .env.example .env      ← then fill in only what you use
#
# Everything here is OPTIONAL. Leave a line commented out to disable that
# backend — the agent simply skips it. The .env file is gitignored, so your
# keys can never end up on GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# Primary backend: claude | codex | deepseek | openrouter | gemini | local
# Comment out to use the automatic cascade (gemini → deepseek → openrouter → local).
AI_BACKEND=claude

# ── Claude ── no API key needed! Uses your claude.ai account through the
# official Claude Code CLI (install it, run `claude login` once).
CLAUDE_MODEL=sonnet                              # sonnet | haiku | opus

# ── Codex ── no API key needed! Uses your ChatGPT account through the
# official OpenAI Codex CLI (install it, run `codex login` once).
# CODEX_MODEL=gpt-5.2-codex                      # omit to use your codex default
# CODEX_EFFORT=medium                            # minimal | low | medium | high

# ── DeepSeek (direct API) ── key from https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-v4-flash                 # or deepseek-v4-pro

# ── OpenRouter ── one key, hundreds of models — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-v4-flash # any slug from openrouter.ai/models

# ── Gemini ── key from https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza-your-key-here
# CLOUD_MODEL=gemini-3.1-flash-lite

# ── Local model ── no key; run a llama.cpp server on :8080 (see start-hermes.sh)
